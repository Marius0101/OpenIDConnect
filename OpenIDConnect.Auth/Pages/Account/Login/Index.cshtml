@page
@model OpenIDConnect.Auth.Pages.Account.Login.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login</title>
</head>
<body>
    <h2>Login</h2>
    <form method="post">
        <label>Username:</label>
        <input asp-for="Input.Username" />
        <br />
        <label>Password:</label>
        <input asp-for="Input.Password" type="password" />
        <br />
        <button type="submit">Login</button>
    </form>
    <p style="color:red">@Model.Error</p>
</body>
</html>